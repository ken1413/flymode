{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlyMode",
  "version": "0.3.0",
  "identifier": "com.flymode.app",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../src-ui && npm run build",
    "beforeDevCommand": "cd ../src-ui && npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FlyMode - Wireless Scheduler",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 600,
        "minHeight": 400,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Wireless control scheduler",
    "longDescription": "Automatically toggle WiFi, Bluetooth, or run custom commands on a schedule",
    "linux": {
      "deb": {
        "depends": ["network-manager", "rfkill"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
